{
  "manifest_version": 3,
  "name": "ByteLocker",
  "version": "1.0",
  "description": "Generate strong passwords instantly.",
  "permissions": ["storage", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}